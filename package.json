{
  "name": "auklet",
  "version": "0.0.19",
  "type": "module",
  "author": "chentao.arthur",
  "packageManager": "pnpm@10.27.0",
  "description": "Build utilities for TypeScript packages and module CSS output.",
  "engines": {
    "node": ">=22",
    "pnpm": "=10.27.0"
  },
  "bin": {
    "auk": "./bin/entry.cjs",
    "auklet": "./bin/entry.cjs"
  },
  "scripts": {
    "prepare": "husky",
    "build": "rimraf dist && tsc -p tsconfig.json",
    "test": "vitest run src/__tests__",
    "test:examples": "pnpm build:examples && vitest run examples/__tests__",
    "test:coverage": "vitest run src/__tests__ --coverage",
    "typecheck": "tsc --noEmit --skipLibCheck",
    "dev:examples": "pnpm --filter './examples/*' --if-present dev",
    "build:examples": "pnpm --filter './examples/*' build",
    "format:md": "prettier --write \"*.md\" \"examples/**/*.md\"",
    "format": "prettier --write \"package.json\" \"pnpm-workspace.yaml\" \"(bin|src|dist|examples)/**/*.{js,mjs,cjs,ts,tsx,json,md,yaml,css}\""
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "imports": {
    "#auklet/*": {
      "source": "./src/*.ts",
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "license": "MIT",
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/imtaotao/auklet.git"
  },
  "bugs": {
    "url": "https://github.com/imtaotao/auklet/issues"
  },
  "files": [
    "bin",
    "dist",
    "!dist/__tests__"
  ],
  "keywords": [
    "build",
    "typescript",
    "css",
    "vite",
    "components",
    "monorepo",
    "tsdown"
  ],
  "dependencies": {
    "unrun": "catalog:",
    "execa": "catalog:",
    "aidly": "catalog:",
    "rimraf": "catalog:",
    "tsdown": "catalog:",
    "semver": "catalog:",
    "postcss": "catalog:",
    "chokidar": "catalog:",
    "minimist": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:",
    "conditional-export": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/semver": "catalog:",
    "@types/minimist": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "husky": "catalog:",
    "lint-staged": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "lint-staged": {
    "*.js": [
      "prettier --write"
    ],
    "*.ts?(x)": [
      "prettier --parser=typescript --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
