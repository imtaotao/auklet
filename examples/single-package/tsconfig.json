{
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["dist", "node_modules"],
  "compilerOptions": {
    "target": "ES2018",
    "module": "preserve",
    "moduleResolution": "Bundler",
    "jsx": "preserve",
    "rootDir": ".",
    "outDir": "dist",
    "declaration": true,
    "strict": true,
    "skipLibCheck": true
  }
}
