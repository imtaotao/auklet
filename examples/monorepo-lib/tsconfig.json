{
  "include": ["packages/*/src/**/*.ts"],
  "exclude": ["**/dist", "node_modules"],
  "compilerOptions": {
    "target": "ES2018",
    "module": "preserve",
    "moduleResolution": "Bundler",
    "rootDir": ".",
    "outDir": "dist",
    "declaration": true,
    "strict": true,
    "skipLibCheck": true
  }
}
