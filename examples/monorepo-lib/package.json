{
  "name": "@demo/monorepo-lib",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "auk build --workspace",
    "publish:dry-run": "cross-env NPM_CONFIG_CACHE=.publish-cache auk publish --workspace --dry-run",
    "publish:local": "cross-env NPM_CONFIG_CACHE=.publish-cache auk publish --workspace --version patch --allow-dirty"
  },
  "auklet": {
    "publish": {
      "beforePublish": "node -e \"console.log('[publish-demo] beforePublish', process.env.AUKLET_PUBLISH_DRY_RUN, process.env.AUKLET_PUBLISH_PACKAGES)\"",
      "afterPublish": "node -e \"console.log('[publish-demo] afterPublish', process.env.AUKLET_PUBLISH_RESULT, process.env.AUKLET_PUBLISH_ERROR || process.env.AUKLET_PUBLISH_PACKAGES)\""
    }
  },
  "devDependencies": {
    "auklet": "link:../..",
    "cross-env": "catalog:"
  }
}
