{
  "name": "@demo/reexports",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "build": "auk build"
  },
  "dependencies": {
    "@demo/ui": "workspace:*"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "registry": "http://127.0.0.1:4873"
  },
  "devDependencies": {
    "auklet": "link:../../../.."
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./components/*": {
      "types": "./dist/es/components/*/index.d.ts",
      "default": "./dist/es/components/*/index.js"
    },
    "./style.css": "./dist/index.css",
    "./components/*.css": "./dist/es/components/*/style/index.css"
  }
}
